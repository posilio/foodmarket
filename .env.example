# Root-level environment variable examples for the FoodWebshop monorepo.
# Copy this file to .env and fill in real values. Never commit real secrets.

# PostgreSQL connection (used by docker-compose and the backend)
# Note: port 5433 avoids conflict with any native PostgreSQL on 5432
POSTGRES_USER=foodwebshop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=foodwebshop_dev
DATABASE_URL=postgresql://foodwebshop:changeme@localhost:5433/foodwebshop_dev
