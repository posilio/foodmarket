// Prisma schema — defines the database connection and all data models for FoodWebshop.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING // Order created, not yet paid
  PAID // Payment confirmed
  PROCESSING // Being prepared for shipment
  SHIPPED // Handed to courier
  DELIVERED // Confirmed delivered
  CANCELLED // Cancelled before shipment
  REFUNDED // Refunded after payment
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CategoryType {
  ORIGIN_REGION
  ORIGIN_COUNTRY
  PRODUCT_TYPE
}

enum DietaryLabel {
  VEGAN
  VEGETARIAN
  HALAL
  KOSHER
  GLUTEN_FREE
  DAIRY_FREE
  NUT_FREE
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum AllergenType {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOYBEANS
  MILK
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS
}

// ─── Models ───────────────────────────────────────────────────────────────────

// A hierarchical category node: either an origin region, origin country, or product type.
model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  emoji         String?
  type          CategoryType
  parentId      String?
  parent        Category?     @relation("CategoryChildren", fields: [parentId], references: [id])
  children      Category[]    @relation("CategoryChildren")
  createdAt     DateTime      @default(now())
  products      Product[]     @relation("ProductOrigin")
  typedProducts Product[]     @relation("ProductType")
}

// A product in the catalogue; actual purchasable items are ProductVariants.
model Product {
  id              String                @id @default(cuid())
  name            String
  slug            String                @unique
  description     String?
  imageUrl        String?
  brandName       String?
  countryOfOrigin  String?
  originCategoryId String
  category         Category              @relation("ProductOrigin", fields: [originCategoryId], references: [id])
  typeCategoryId   String?
  typeCategory     Category?             @relation("ProductType", fields: [typeCategoryId], references: [id])
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  variants         ProductVariant[]
  allergens        ProductAllergen[]
  dietaryLabels    ProductDietaryLabel[]
  reviews          Review[]

  @@index([originCategoryId])
  @@index([isActive])
}

// A purchasable size/weight variant of a product with its own price and stock.
model ProductVariant {
  id             String      @id @default(cuid())
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  sku            String      @unique
  ean            String?     @unique
  label          String
  weightGrams    Int?
  volumeMl       Int?
  priceEuroCents Int
  stockQuantity  Int         @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderLines     OrderLine[]

  @@index([productId])
  @@index([stockQuantity])
  @@index([isActive])
}

// Join table linking a product to the EU-14 allergens it contains.
model ProductAllergen {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  allergen  AllergenType

  @@unique([productId, allergen])
}

// Join table linking a product to its dietary certification labels.
model ProductDietaryLabel {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  label     DietaryLabel

  @@unique([productId, label])
}

// A registered customer account.
model Customer {
  id                   String               @id @default(cuid())
  email                String               @unique
  passwordHash         String
  firstName            String
  lastName             String
  phone                String?
  isActive             Boolean              @default(true)
  isAdmin              Boolean              @default(false)
  failedLoginAttempts  Int                  @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  addresses            Address[]
  orders               Order[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  reviews              Review[]
  loyaltyPoints        LoyaltyPoint[]
}

// Short-lived token used to verify a password-reset request.
model PasswordResetToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

// Sequential invoice number per calendar year, one row per paid order.
model InvoiceNumber {
  id        Int      @id @default(autoincrement())
  year      Int
  sequence  Int
  orderId   String   @unique
  createdAt DateTime @default(now())

  @@unique([year, sequence])
}

// Opaque refresh tokens for the silent-refresh auth flow.
model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

// A delivery address belonging to a customer (NL address format).
model Address {
  id                  String   @id @default(cuid())
  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id])
  street              String
  houseNumber         String
  houseNumberAddition String?
  postalCode          String
  city                String
  country             String   @default("NL")
  isDefault           Boolean  @default(false)
  createdAt           DateTime @default(now())
  orders              Order[]
}

// A customer order containing one or more product variant lines.
model Order {
  id                String       @id @default(cuid())
  customerId        String
  customer          Customer     @relation(fields: [customerId], references: [id])
  status            OrderStatus  @default(PENDING)
  shippingAddressId String
  shippingAddress   Address      @relation(fields: [shippingAddressId], references: [id])
  totalEuroCents             Int
  shippingCents              Int           @default(0)
  discountCodeId             String?
  discountEuroCents          Int           @default(0)
  loyaltyPointsRedeemed      Int           @default(0)
  loyaltyPointsDiscountCents Int           @default(0)
  notes                      String?
  stockReservedUntil         DateTime?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  lines                      OrderLine[]
  payment                    Payment?
  events                     OrderEvent[]
  discountCode               DiscountCode? @relation(fields: [discountCodeId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([stockReservedUntil])
}

// A single product variant line within an order; price is frozen at order time.
model OrderLine {
  id                 String         @id @default(cuid())
  orderId            String
  order              Order          @relation(fields: [orderId], references: [id])
  variantId          String
  variant            ProductVariant @relation(fields: [variantId], references: [id])
  quantity           Int
  unitPriceEuroCents Int
  createdAt          DateTime       @default(now())

  @@index([orderId])
}

// The payment record associated with an order (one-to-one).
model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id])
  status            PaymentStatus @default(PENDING)
  providerReference String?
  amountEuroCents   Int
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([providerReference])
}

// Append-only audit log recording every significant event on an order.
model OrderEvent {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id])
  eventType  String
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  note       String?
  createdAt  DateTime     @default(now())
}

// A promotional discount code that can be applied at checkout.
model DiscountCode {
  id          String       @id @default(cuid())
  code        String       @unique
  type        DiscountType
  amountCents Int?
  percent     Int?
  maxUses     Int?
  usedCount   Int          @default(0)
  expiresAt   DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  orders      Order[]
}

// Loyalty points ledger — each row is a credit (positive) or debit (negative).
model LoyaltyPoint {
  id         String   @id @default(cuid())
  customerId String
  points     Int
  reason     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// Customer review of a product (one per customer per product).
model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  rating     Int
  body       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, customerId])
  @@index([productId])
}
