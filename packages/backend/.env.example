# Environment variables for the backend API.
# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=4000
NODE_ENV=development

# Database (Prisma connection string)
# Note: port 5433 avoids conflict with any native PostgreSQL on 5432
DATABASE_URL=postgresql://foodwebshop:changeme@localhost:5433/foodwebshop_dev

# Auth — use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Payment provider (e.g. Mollie for NL market)
# MOLLIE_API_KEY=

# Logging
LOG_LEVEL=info
